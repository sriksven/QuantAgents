# syntax=docker/dockerfile:1
FROM python:3.11-slim AS base

RUN pip install --no-cache-dir uv

WORKDIR /app

COPY data-pipeline/ ./

# Install data pipeline dependencies
RUN uv pip install --system \
    yfinance \
    pandas \
    numpy \
    requests \
    httpx \
    pyarrow \
    great-expectations \
    dvc \
    structlog \
    tavily-python \
    scipy

CMD ["python", "-m", "pytest", "tests/", "-v"]
