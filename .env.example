# ============================================================
# QuantAgents — Environment Variables
# Copy to .env and fill in your values. Never commit .env!
# ============================================================

# ─── LLM ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini

# ─── Broker ─────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_PAPER=true                        # true = paper trading, false = live
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Data APIs ──────────────────────────────────────────────
TAVILY_API_KEY=tvly-...                  # 1,000 searches/month free
ALPHA_VANTAGE_API_KEY=your_av_key       # 25 requests/day free
# yfinance and SEC EDGAR need no API key

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=quantagents
POSTGRES_PASSWORD=quantagents_secret
POSTGRES_DB=quantagents
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://quantagents:quantagents_secret@localhost:5432/quantagents

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant ──────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=quantagents_knowledge

# ─── Langfuse ────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ─── MLflow ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=quantagents

# ─── Airflow ────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=your_fernet_key
AIRFLOW__WEBSERVER__SECRET_KEY=your_webserver_secret

# ─── Notifications ───────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...  # optional

# ─── Backend ─────────────────────────────────────────────────
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── Feature Flags ───────────────────────────────────────────
ENABLE_QUANTUM=true
ENABLE_LIVE_TRADING=false                # Master kill-switch for live trades
MAX_DEBATE_ROUNDS=2
KELLY_FRACTION=0.5                       # 0.5 = half-Kelly
BACKTEST_SHARPE_THRESHOLD=1.0
CONFIDENCE_THRESHOLD=0.65
MAX_POSITION_PCT=0.30                    # Max 30% of equity in one position
MAX_DAILY_LOSS_PCT=0.05                  # Halt trading if down 5% in a day
